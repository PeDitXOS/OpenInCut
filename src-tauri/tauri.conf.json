{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenInCut",
  "version": "0.1.0",
  "identifier": "net.pequesoft.opencut",
  "build": {
    "devUrl": "http://localhost:5175",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenInCut",
        "width": 1600,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
