{
  "id": "core.chroma_key",
  "name": "Chroma Key",
  "category": "keying",
  "params": [
    { "key": "key_color", "label": "Key color", "type": "color", "default": "#00ff00" },
    { "key": "similarity", "label": "Similarity", "type": "float", "default": 0.3, "min": 0.01, "max": 1.0 },
    { "key": "blend", "label": "Blend", "type": "float", "default": 0.1, "min": 0.0, "max": 0.5 },
    { "key": "despill", "label": "Despill", "type": "float", "default": 0.6, "min": 0.0, "max": 1.0 }
  ],
  "ffmpeg": "chromakey=color={key_color}:similarity={similarity}:blend={blend},format=yuva444p,despill=type=green:mix={despill},premultiply=inplace=1",
  "notes": "v0: the keyed area is composited over black (premultiply). Real compositing with the track below arrives with the wgpu engine."
}
