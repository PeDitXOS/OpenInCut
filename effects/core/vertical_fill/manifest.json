{
  "id": "core.vertical_fill",
  "name": "Vertical: blurred background",
  "category": "layout",
  "params": [
    { "key": "width", "label": "Width", "type": "float", "default": 1080, "min": 320, "max": 2160 },
    { "key": "height", "label": "Height", "type": "float", "default": 1920, "min": 320, "max": 3840 },
    { "key": "blur", "label": "Blur", "type": "float", "default": 20, "min": 0, "max": 60 }
  ],
  "ffmpeg": "split[{u}a][{u}b];[{u}a]scale={width}:{height}:force_original_aspect_ratio=increase,crop={width}:{height},gblur=sigma={blur}[{u}bg];[{u}b]scale={width}:-2[{u}fg];[{u}bg][{u}fg]overlay=(W-w)/2:(H-h)/2",
  "notes": "The look from the toolkit's shorts.py: the same image scaled to bleed and blurred as the background, with the video centered on top."
}
